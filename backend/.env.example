# Backend environment variables (copy to backend/.env before deploying)
# ==========================================

# DashScope AI
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.5-plus

# Innomate API
INNOMATE_API_URL=http://172.24.0.4/murata-flowable-process/findData

# Auth
SECRET_KEY=your-random-secret-key-change-this
UNIFIED_PASSWORD=admin123

# Dify Knowledge Base
DIFY_API_KEY=your-dify-api-key
DIFY_BASE_URL=http://dify-host/v1
DIFY_DATASET_ID=your-dataset-id
DIFY_INDEX_DATASET_ID=

# Batch processing
BATCH_CONCURRENCY=3

# PostgreSQL Database
DATABASE_URL=postgresql+psycopg2://appuser:apppassword@db:5432/ai_data_platform

# Data directories (inside container)
MD_RAW_DIR=/data/raw
MD_REDACTED_DIR=/data/redacted
INDEX_DIR=/data/index

# Prompts directory
PROMPTS_DIR=/app/prompts
